# Database credentials
POSTGRES_DB=localloom
POSTGRES_USER=localloom
POSTGRES_PASSWORD=localloom

# Image version tag
VERSION=latest

# Frontend API proxy target (used in next.config.js)
API_URL=http://api:8080

# Whisper transcription (Apple Silicon: use int8_float16 for 2x speed)
# LOCALLOOM_WHISPER_COMPUTE_TYPE=int8_float16
